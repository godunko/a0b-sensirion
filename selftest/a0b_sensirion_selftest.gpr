with "config/a0b_sensirion_selftest_config.gpr";

with "a0b_common.gpr";

project A0B_Sensirion_Selftest is

   for Exec_Dir use "bin";
   for Object_Dir use ".objs/" & A0B_Common.Object_Dir_Suffix;
   for Main use ("selftest.adb");

   package Compiler is
      for Switches ("Ada") use A0B_Common.Compiler_Switches_Ada;
   end Compiler;

end A0B_Sensirion_Selftest;
